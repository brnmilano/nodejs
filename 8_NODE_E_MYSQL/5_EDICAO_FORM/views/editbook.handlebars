<h1>
  Edite o seu livro
</h1>

<form action="/books/update" method="post" class="form">
  <div class="form-control">
    <label for="title">Título:</label>
    <input
      type="text"
      id="title"
      name="title"
      placeholder="Digite o título"
      value="{{book.title}}"
      required
    />
  </div>

  <div class="form-control">
    <label for="pageqty">Quantidade de Páginas:</label>
    <input
      type="number"
      id="pageqty"
      name="pageqty"
      placeholder="Digite a quantidade de páginas"
      value="{{book.pageqty}}"
      required
    />
  </div>

  <button type="submit">Editar Livro</button>
</form>