<div id="book-page">

  <div class="container">
    <h1>{{book.title}}</h1>
    <p>Páginas: {{book.pageqty}}</p>

    <div class="actions">
      <a href="/books/edit/{{book.id}}" class="btn btn-primary">
        Editar Livro
      </a>

      <form action="/books/remove/{{book.id}}" method="POST">
        <button type="submit" class="btn btn-danger">
          Remover Livro
        </button>
      </form>
    </div>

    <a href="/books">
      Voltar para a lista de livros
    </a>
  </div>
</div>