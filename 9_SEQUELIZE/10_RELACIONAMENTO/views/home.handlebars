<h1>
  Usuários cadastrados:

</h1>

<div class="container">
  {{#each users}}
    <div class="item">
      <p>
        <strong>Nome:</strong>
        {{this.name}}
      </p>

      <p>
        <strong>Profissão:</strong>
        {{this.occupation}}
      </p>

      <div class="actions">
        <a href="/users/{{this.id}}" class="details-btn">Detalhes</a>

        <a href="/users/edit/{{this.id}}" class="edit-btn">Editar</a>

        <form action="/users/delete/{{this.id}}" method="POST">
          <button type="submit" class="delete-btn">Excluir</button>
        </form>
      </div>
    </div>
  {{/each}}
</div>